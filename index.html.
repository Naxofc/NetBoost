    // Desaparece com opacidade quando footer está chegando (280px antes)
    const shouldShow = scrollY > 80;
    const nearFooter = footerTop < winH + 200;
    
    if (!shouldShow) {
      blur.classList.remove('visible', 'hiding');
    } else if (nearFooter) {
      blur.classList.remove('visible');
      blur.classList.add('hiding');
    } else {
      blur.classList.remove('hiding');
      blur.classList.add('visible');
    }
  }

  window.addEventListener('scroll', updateBlur, { passive: true });
  updateBlur();
</script>
<script>
(function() {
  var container = document.getElementById('dotted-surface');
  if (!container || !window.THREE) return;

  var SEPARATION = 140, AMOUNTX = 38, AMOUNTY = 55;

  var scene = new THREE.Scene();
  var camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 1, 10000);
  camera.position.set(0, 320, 1150);

  var renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(window.innerWidth, window.innerHeight);
  renderer.setClearColor(0x000000, 0);
  container.appendChild(renderer.domElement);

  // Criar geometria de pontos
  var geometry = new THREE.BufferGeometry();
  var positions = [];
  var colors = [];

  for (var ix = 0; ix < AMOUNTX; ix++) {
    for (var iy = 0; iy < AMOUNTY; iy++) {
      positions.push(
        ix * SEPARATION - (AMOUNTX * SEPARATION) / 2,
        0,
        iy * SEPARATION - (AMOUNTY * SEPARATION) / 2
      );
      // Azul Netboost: R=26/255, G=115/255, B=232/255 normalizado para 0-1 e depois 0-255 para vertex colors
      colors.push(0.35, 0.65, 1.0); // blue-ish: #59A6FF roughly
    }
  }

  geometry.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));
  geometry.setAttribute('color', new THREE.Float32BufferAttribute(colors, 3));

  var material = new THREE.PointsMaterial({
    size: 5,
    vertexColors: true,
    transparent: true,
    opacity: 0.45,
    sizeAttenuation: true
  });

  var points = new THREE.Points(geometry, material);
  scene.add(points);

  var count = 0;

  function animate() {
    requestAnimationFrame(animate);

    var posAttr = geometry.attributes.position;
    var pos = posAttr.array;

    var i = 0;
    for (var ix = 0; ix < AMOUNTX; ix++) {
      for (var iy = 0; iy < AMOUNTY; iy++) {
        pos[i * 3 + 1] =
          Math.sin((ix + count) * 0.3) * 45 +
          Math.sin((iy + count) * 0.5) * 45;
        i++;
      }
    }

    posAttr.needsUpdate = true;
    renderer.render(scene, camera);
    count += 0.07;
  }

  window.addEventListener('resize', function() {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
  });

  animate();
})();
</script>

