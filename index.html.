<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Netboost — Tráfego para Food Service</title>
<link href="https://fonts.googleapis.com/css2?family=Exo+2:wght@300;400;600;700;800;900&family=Barlow+Condensed:wght@400;600;700;800;900&family=Orbitron:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  :root {
    --blue-1: #1a73e8;
    --blue-2: #0d47a1;
    --blue-3: #42a5f5;
    --dark: #050a14;
    --dark-2: #0a1525;
    --white: #ffffff;
    --gray: #8090a8;
    --border: rgba(26,115,232,0.18);
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior:smooth; }
  body { font-family:'Exo 2',sans-serif; background:var(--dark); color:var(--white); overflow-x:hidden; }

  .grad-text {
    background: linear-gradient(90deg,#42a5f5,#1a73e8,#0d47a1,#42a5f5,#64b5f6);
    background-size: 300% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradShift 4s linear infinite;
  }
  @keyframes gradShift { 0%{background-position:0% 50%} 100%{background-position:300% 50%} }

  .section-label {
    font-family:'Orbitron',sans-serif;
    font-size:0.7rem; font-weight:800;
    letter-spacing:0.25em; color:var(--blue-3);
    text-transform:uppercase; margin-bottom:14px; display:block;
  }

  /* ── HEADER ── */
  header {
    position:fixed; top:0; left:0; right:0; z-index:100;
    background:rgba(5,10,20,0.92);
    backdrop-filter:blur(18px);
    border-bottom:1px solid var(--border);
    display:flex; align-items:center; justify-content:space-between;
    padding:0 48px; height:64px;
  }
  .header-logo img { height:22px; max-width:130px; display:block; object-fit:contain; }
  nav { display:flex; gap:32px; align-items:center; }
  nav a {
    font-family:'Orbitron',sans-serif;
    font-size:0.72rem; font-weight:700; color:var(--gray); white-space:nowrap;
    text-decoration:none; letter-spacing:0.1em; text-transform:uppercase; transition:color 0.2s;
  }
  nav a:hover { color:var(--white); }

  /* ── BUTTONS ── */
  .btn-primary {
    display:inline-block;
    background:linear-gradient(135deg,var(--blue-1),var(--blue-2));
    color:#fff; font-family:'Orbitron',sans-serif;
    font-weight:700; font-size:0.68rem; letter-spacing:0.03em; text-transform:uppercase;
    padding:11px 16px; white-space:nowrap; border-radius:6px; text-decoration:none;
    box-shadow:0 4px 20px rgba(26,115,232,0.4); transition:transform 0.15s,box-shadow 0.15s;
  }
  .btn-primary:hover { transform:translateY(-2px); box-shadow:0 8px 32px rgba(26,115,232,0.6); }

  .btn-glow {
    display:inline-block;
    background:linear-gradient(135deg,#1a73e8,#0d47a1,#42a5f5);
    background-size:200% 200%; animation:gradShift 3s ease infinite;
    color:#fff; font-family:'Orbitron',sans-serif;
    font-weight:800; font-size:0.75rem; letter-spacing:0.05em; text-transform:uppercase;
    padding:16px 36px; border-radius:8px; text-decoration:none;
    box-shadow:0 0 20px rgba(26,115,232,0.7),0 0 40px rgba(26,115,232,0.35);
    transition:transform 0.2s,box-shadow 0.2s;
  }
  .btn-glow:hover { transform:translateY(-3px) scale(1.03); box-shadow:0 0 34px rgba(66,165,245,0.9),0 0 68px rgba(26,115,232,0.5); }

  .btn-outline {
    display:inline-block; border:1.5px solid var(--blue-1); color:var(--blue-3);
    font-family:'Orbitron',sans-serif; font-weight:700; font-size:0.65rem;
    letter-spacing:0.08em; text-transform:uppercase; padding:12px 28px;
    border-radius:6px; text-decoration:none; transition:all 0.2s; background:transparent;
  }
  .btn-outline:hover { background:rgba(26,115,232,0.1); box-shadow:0 0 18px rgba(26,115,232,0.3); }

  .btn-glow-sm {
    display:block; background:linear-gradient(135deg,#1a73e8,#1565c0);
    color:#fff; font-family:'Orbitron',sans-serif;
    font-weight:700; font-size:0.65rem; letter-spacing:0.05em; text-transform:uppercase;
    padding:14px 24px; border-radius:6px; text-decoration:none; text-align:center;
    box-shadow:0 0 14px rgba(26,115,232,0.6),0 0 28px rgba(26,115,232,0.3);
    transition:transform 0.15s,box-shadow 0.2s; margin-top:8px;
  }
  .btn-glow-sm:hover { transform:translateY(-2px); box-shadow:0 0 22px rgba(66,165,245,0.8),0 0 44px rgba(26,115,232,0.5); }

  .btn-saiba {
    display:inline-flex; align-items:center; gap:6px;
    color:var(--blue-3); font-family:'Orbitron',sans-serif;
    font-weight:700; font-size:0.62rem; letter-spacing:0.06em; text-transform:uppercase;
    text-decoration:none; border-bottom:1px solid rgba(66,165,245,0.35);
    padding-bottom:2px; transition:all 0.2s; margin-top:12px;
  }
  .btn-saiba:hover { color:#fff; border-color:#fff; }
  .btn-saiba::after { content:'→'; transition:transform 0.2s; }
  .btn-saiba:hover::after { transform:translateX(4px); }

  /* ── HERO ── */
  #hero {
    min-height:100vh; padding-top:64px;
    display:flex; align-items:center;
    position:relative; overflow:hidden;
  }
  .hero-bg { position:absolute; inset:0; background:radial-gradient(ellipse 60% 80% at 68% 50%,rgba(26,115,232,0.08) 0%,transparent 70%); }
  .grid-lines {
    position:absolute; inset:0; opacity:0.07; pointer-events:none;
    background-image:linear-gradient(var(--blue-1) 1px,transparent 1px),linear-gradient(90deg,var(--blue-1) 1px,transparent 1px);
    background-size:60px 60px;
  }
  /* Blobs */
  .hero-blob {
    position:absolute; border-radius:50%; filter:blur(90px);
    opacity:0; animation:blobFade 1s ease forwards; pointer-events:none;
  }
  .hero-blob-1 { width:520px;height:520px; right:2%;top:5%;
    background:radial-gradient(circle,rgba(26,115,232,0.5) 0%,transparent 70%);
    animation:blobFade 1s ease 0.2s forwards,blobP1 6s ease-in-out 1.2s infinite; }
  .hero-blob-2 { width:400px;height:400px; right:22%;top:28%;
    background:radial-gradient(circle,rgba(13,71,161,0.55) 0%,transparent 70%);
    animation:blobFade 1s ease 0.5s forwards,blobP2 8s ease-in-out 1.5s infinite; }
  .hero-blob-3 { width:300px;height:300px; right:5%;top:58%;
    background:radial-gradient(circle,rgba(66,165,245,0.4) 0%,transparent 70%);
    animation:blobFade 1s ease 0.8s forwards,blobP3 5s ease-in-out 1.8s infinite; }
  .hero-blob-4 { width:350px;height:350px; right:36%;top:8%;
    background:radial-gradient(circle,rgba(100,181,246,0.3) 0%,transparent 70%);
    animation:blobFade 1s ease 1s forwards,blobP2 7s ease-in-out 2s infinite; }
  .hero-blob-5 { width:260px;height:260px; right:14%;top:68%;
    background:radial-gradient(circle,rgba(26,115,232,0.35) 0%,transparent 70%);
    animation:blobFade 1s ease 1.2s forwards,blobP1 9s ease-in-out 2.2s infinite; }
  @keyframes blobFade { to{opacity:1} }
  @keyframes blobP1 { 0%,100%{transform:scale(1) translate(0,0);opacity:.7} 50%{transform:scale(1.15) translate(-20px,20px);opacity:1} }
  @keyframes blobP2 { 0%,100%{transform:scale(1) translate(0,0);opacity:.8} 50%{transform:scale(.88) translate(25px,-15px);opacity:1} }
  @keyframes blobP3 { 0%,100%{transform:scale(1) translate(0,0);opacity:.6} 50%{transform:scale(1.2) translate(-10px,25px);opacity:.9} }

  .hero-inner {
    max-width:1200px; margin:0 auto; padding:60px 48px;
    display:grid; grid-template-columns:1.1fr 0.9fr; gap:100px;
    align-items:center; position:relative; z-index:2; width:100%;
  }
  .hero-label {
    font-family:'Orbitron',sans-serif; font-size:0.62rem;
    font-weight:700; letter-spacing:0.2em; color:var(--blue-3);
    text-transform:uppercase; margin-bottom:8px; opacity:0.9;
  }
  .hero-question { font-size:clamp(1.5rem,3vw,2.1rem); font-weight:800; margin-bottom:8px; }
  .hero-name { font-size:clamp(2.2rem,4.5vw,3.8rem); font-weight:900; line-height:1.05; margin-bottom:24px; letter-spacing:-0.02em; }
  .hero-desc { font-size:1.05rem; color:rgba(255,255,255,0.72); line-height:1.75; margin-bottom:36px; font-weight:300; }
  .hero-stats { display:flex; gap:36px; margin-bottom:40px; }
  .stat-item { text-align:left; }
  .stat-num { font-family:'Orbitron',sans-serif; font-size:2rem; font-weight:700; display:block; }
  .stat-label { font-size:0.75rem; color:var(--gray); letter-spacing:0.05em; text-transform:uppercase; }
  .hero-ctas { display:flex; gap:14px; flex-wrap:wrap; }

  /* Photo side */
  .hero-photo-side { display:flex; flex-direction:column; justify-content:flex-end; align-items:center; position:relative; }
  .photo-frame {
    position:relative; width:360px; max-width:100%;
    border-radius:12px; overflow:hidden;
  }
  .photo-frame::before {
    content:''; position:absolute; inset:-2px;
    background:linear-gradient(135deg,var(--blue-1),transparent 50%,var(--blue-2));
    border-radius:12px; z-index:0;
  }
  .photo-frame img { position:relative; z-index:1; width:100%; display:block; border-radius:10px; }
  .photo-badge {
    position:absolute; bottom:24px; left:-24px;
    background:rgba(13,22,40,0.95); border:1px solid var(--border);
    border-radius:8px; padding:12px 18px; backdrop-filter:blur(12px); z-index:3;
  }

  /* ── SCROLL BLUR ── */
  .scroll-blur-bottom {
    position:fixed; bottom:0; left:0; right:0; height:160px;
    background:linear-gradient(to top,rgba(5,10,20,0.92) 0%,transparent 100%);
    backdrop-filter:blur(5px); -webkit-backdrop-filter:blur(5px);
    pointer-events:none; z-index:50;
    opacity:0; transition:opacity 0.5s ease;
  }
  .scroll-blur-bottom.visible { opacity:1; }
  .scroll-blur-bottom.hiding { opacity:0; }

  /* ── CONTAINER / SECTIONS ── */
  .container { max-width:1200px; margin:0 auto; padding:0 48px; }
  section { padding:100px 0; }
  .section-title { font-size:clamp(1.8rem,3.5vw,2.8rem); font-weight:800; line-height:1.15; margin-bottom:16px; letter-spacing:-0.01em; }
  .section-sub { font-size:1rem; color:rgba(255,255,255,0.6); line-height:1.7; max-width:560px; }

  /* ── CLIENTES BAND ── */
  #clientes-band { padding:40px 0; border-top:1px solid var(--border); border-bottom:1px solid var(--border); }
  .band-label { text-align:center; font-family:'Orbitron',sans-serif; font-size:0.82rem; font-weight:800; letter-spacing:0.25em; color:var(--gray); text-transform:uppercase; margin-bottom:28px; }
  .clients-row { display:flex; justify-content:center; gap:60px; flex-wrap:wrap; align-items:center; }
  .client-name { font-family:'Orbitron',sans-serif; font-weight:700; font-size:1.1rem; color:rgba(255,255,255,0.35); letter-spacing:0.05em; text-transform:uppercase; transition:color 0.2s; cursor:default; }
  .client-name:hover { color:rgba(255,255,255,0.7); }

  /* ── SOBRE ── */
  .about-grid { display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:center; }
  .about-features { margin-top:32px; display:flex; flex-direction:column; gap:18px; }
  .about-feat { display:flex; gap:16px; align-items:flex-start; }
  .feat-icon { width:40px;height:40px; border-radius:8px; background:rgba(26,115,232,0.12); border:1px solid rgba(26,115,232,0.25); display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:1.1rem; }
  .feat-text h4 { font-size:0.95rem; font-weight:700; margin-bottom:4px; }
  .feat-text p { font-size:0.85rem; color:var(--gray); line-height:1.6; }
  .about-visual { position:relative; height:380px; border-radius:12px; overflow:hidden; border:1px solid var(--border); }
  .metrics-grid { position:absolute; inset:0; display:grid; grid-template-columns:1fr 1fr; gap:2px; padding:24px; align-content:center; }
  .metric-card { background:rgba(5,10,20,0.7); border:1px solid var(--border); border-radius:8px; padding:20px; text-align:center; backdrop-filter:blur(8px); }
  .metric-num { font-family:'Orbitron',sans-serif; font-size:1.7rem; font-weight:700; display:block; margin-bottom:4px; }
  .metric-label { font-size:0.72rem; color:var(--gray); text-transform:uppercase; letter-spacing:0.08em; }

  /* ── PARA QUEM ── */
  #para-quem { background:var(--dark); }
  .para-quem-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:24px; margin-top:48px; }
  .para-quem-card {
    background:var(--dark-2); border:1px solid rgba(26,115,232,0.22);
    border-radius:14px; padding:32px;
    transition:transform 0.2s, box-shadow 0.3s, border-color 0.3s;
    position:relative; overflow:hidden;
  }
  .para-quem-card::before {
    content:''; position:absolute; top:0; left:0; right:0; height:2px;
    background:linear-gradient(90deg,var(--blue-2),var(--blue-3),var(--blue-1));
    background-size:200%; animation:gradShift 3s linear infinite;
  }
  .para-quem-card:hover {
    transform:translateY(-4px);
    border-color:rgba(66,165,245,0.5);
    box-shadow:0 0 28px rgba(26,115,232,0.2);
  }
  .pq-icon { font-size:2rem; margin-bottom:16px; display:block; }
  .pq-title { font-family:'Orbitron',sans-serif; font-size:1.25rem; font-weight:800; letter-spacing:0.05em; margin-bottom:10px; color:var(--white); }
  .pq-text { font-size:0.88rem; color:var(--gray); line-height:1.7; }

  /* ── PACKAGES ── */
  .packages-header { text-align:center; margin-bottom:60px; }
  .packages-header .section-sub { margin:0 auto; text-align:center; }
  .packages-grid { display:grid; grid-template-columns:1fr 1fr; gap:28px; margin-bottom:32px; }

  .package-card {
    background:var(--dark-2);
    border:2px solid rgba(66,165,245,0.55);
    border-radius:14px; padding:36px;
    position:relative; overflow:hidden;
    transition:border-color 0.3s,transform 0.2s,box-shadow 0.3s;
    box-shadow:
      0 0 22px rgba(66,165,245,0.22),
      0 0 50px rgba(26,115,232,0.12),
      inset 0 0 40px rgba(26,115,232,0.04);
  }
  .package-card::before {
    content:''; position:absolute; top:0; left:0; right:0; height:3px;
    background:linear-gradient(90deg,var(--blue-2),var(--blue-3),var(--blue-1));
    background-size:200%; animation:gradShift 3s linear infinite; z-index:1;
  }
  .package-card > * { position:relative; z-index:1; }
  .package-card:hover {
    border-color:rgba(66,165,245,0.92);
    transform:translateY(-6px);
    box-shadow:
      0 0 42px rgba(66,165,245,0.42),
      0 0 80px rgba(26,115,232,0.25),
      inset 0 0 40px rgba(26,115,232,0.06);
  }
  .package-card.featured {
    border-color:rgba(66,165,245,0.75);
    box-shadow:
      0 0 34px rgba(66,165,245,0.32),
      0 0 70px rgba(26,115,232,0.18),
      inset 0 0 50px rgba(26,115,232,0.05);
  }
  .pkg-badge { display:inline-block; font-family:'Orbitron',sans-serif; font-size:0.7rem; font-weight:800; letter-spacing:0.2em; text-transform:uppercase; padding:4px 12px; border-radius:20px; background:rgba(26,115,232,0.2); color:var(--blue-3); margin-bottom:20px; border:1px solid rgba(26,115,232,0.35); }
  .pkg-title { font-size:1.7rem; font-weight:800; margin-bottom:8px; letter-spacing:-0.01em; }
  .pkg-subtitle { font-size:0.9rem; color:var(--gray); margin-bottom:28px; line-height:1.65; }
  .pkg-section-label { font-family:'Orbitron',sans-serif; font-size:0.82rem; font-weight:800; letter-spacing:0.2em; color:var(--blue-3); text-transform:uppercase; margin-bottom:12px; }
  .pkg-features { list-style:none; margin-bottom:28px; display:flex; flex-direction:column; gap:11px; }
  .pkg-features li { display:flex; gap:10px; align-items:flex-start; font-size:0.9rem; color:rgba(255,255,255,0.82); line-height:1.5; }
  .pkg-features li::before { content:'→'; color:var(--blue-3); font-size:0.8rem; flex-shrink:0; margin-top:2px; }
  .pkg-bonus { border-top:1px solid rgba(26,115,232,0.2); padding-top:20px; margin-top:4px; margin-bottom:28px; }
  .pkg-bonus-label { font-family:'Orbitron',sans-serif; font-size:0.78rem; font-weight:800; letter-spacing:0.2em; color:var(--blue-3); text-transform:uppercase; margin-bottom:10px; }
  .pkg-bonus ul { list-style:none; display:flex; flex-direction:column; gap:8px; }
  .pkg-bonus ul li { display:flex; gap:10px; align-items:flex-start; font-size:0.85rem; color:rgba(255,255,255,0.65); line-height:1.5; }
  .pkg-bonus ul li::before { content:'⬡'; color:var(--blue-1); font-size:0.7rem; flex-shrink:0; margin-top:3px; }
  .pkg-tag { display:inline-block; font-size:0.72rem; font-family:'Orbitron',sans-serif; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; padding:3px 10px; border-radius:4px; background:rgba(66,165,245,0.12); color:var(--blue-3); border:1px solid rgba(66,165,245,0.25); margin-bottom:16px; margin-right:6px; }

  /* ── DEPOIMENTOS ── */
  .carousel-wrapper { overflow:hidden; position:relative; margin-top:48px; }
  .carousel-track { display:flex; gap:20px; animation:scrollLeft 40s linear infinite; width:max-content; }
  .carousel-track:hover { animation-play-state:paused; }
  @keyframes scrollLeft { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
  .testimonial-card { width:300px; flex-shrink:0; background:var(--dark); border:1px solid var(--border); border-radius:10px; padding:24px; }
  .test-stars { color:var(--blue-3); font-size:0.85rem; letter-spacing:2px; margin-bottom:12px; }
  .test-text { font-size:0.88rem; color:rgba(255,255,255,0.72); line-height:1.7; margin-bottom:16px; font-weight:300; }
  .test-author { display:flex; align-items:center; gap:12px; }
  .test-avatar { width:38px;height:38px; border-radius:50%; background:linear-gradient(135deg,var(--blue-1),var(--blue-2)); display:flex; align-items:center; justify-content:center; font-weight:700; font-size:0.9rem; flex-shrink:0; }
  .test-name { font-weight:700; font-size:0.88rem; }
  .test-biz { font-size:0.75rem; color:var(--gray); }

  /* ── CTA STRIP ── */
  .cta-strip { background:linear-gradient(90deg,rgba(26,115,232,0.1),rgba(13,71,161,0.18),rgba(26,115,232,0.1)); border-top:1px solid rgba(26,115,232,0.2); border-bottom:1px solid rgba(26,115,232,0.2); padding:36px 0; text-align:center; }

  /* ── FOOTER ── */
  footer { border-top:1px solid var(--border); padding:40px 0; }

  /* ── RESPONSIVE ── */
  @media(max-width:768px){
    header { padding:0 20px; }
    nav { display:none; }
    .hero-inner { grid-template-columns:1fr; padding:40px 20px; }
    .hero-photo-side { order:-1; }
    .photo-frame { width:280px; }
    .about-grid,.packages-grid,.para-quem-grid { grid-template-columns:1fr; }
    .container { padding:0 20px; }
    .hero-stats { gap:24px; }
  }

  /* Hero photo side */
  .hero-photo-side {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
  }

  /* Foto do Tiago com fundo preto + gradiente azul atrás */
  .photo-wrap {
    position: relative;
    width: 340px;
    max-width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    border-radius: 12px;
    align-self: flex-start;
    background: #000;
    border: 1.5px solid rgba(26,115,232,0.6);
    min-height: 420px;
    box-shadow:
      0 0 20px rgba(26,115,232,0.45),
      0 0 50px rgba(26,115,232,0.18),
      inset 0 0 30px rgba(26,115,232,0.06);
    overflow: hidden;
  }


  /* Badge CEO no canto inferior esquerdo da foto */
  .ceo-badge-card-UNUSED {
    position: relative;
    z-index: 10;
    margin-bottom: 10px;
    margin-left: 4px;
    animation: badgeFloat 3s ease-in-out infinite;
  }
  @keyframes badgeFloat {
    0%,100% { transform: translateY(0px); }
    50% { transform: translateY(-5px); }
  }
  .ceo-badge-inner {
    background: rgba(8,16,34,0.92);
    border: 1.5px solid rgba(66,165,245,0.55);
    border-radius: 10px;
    padding: 10px 18px;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 0 18px rgba(26,115,232,0.4), 0 4px 20px rgba(0,0,0,0.5);
    text-align: left;
  }
  .ceo-badge-label {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.62rem;
    color: var(--blue-3);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 2px;
  }
  .ceo-badge-name {
    font-family: 'Exo 2', sans-serif;
    font-size: 1rem;
    font-weight: 800;
    color: var(--white);
    letter-spacing: 0.02em;
  }
  .tiago-photo {
    width: 100%;
    display: block;
    border-radius: 0;
